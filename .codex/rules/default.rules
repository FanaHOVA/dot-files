prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["git", "commit", "-m"], decision="allow")
prefix_rule(pattern=["gh", "pr", "create"], decision="allow")
prefix_rule(pattern=["git", "checkout", "-b"], decision="allow")
prefix_rule(pattern=["swift", "test", "--package-path", "HyperReview", "--filter", "codex"], decision="allow")
prefix_rule(pattern=["npm", "run", "test:e2e"], decision="allow")
prefix_rule(pattern=["npm", "run", "test:integration"], decision="allow")
prefix_rule(pattern=["git", "push", "origin"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "python3 /Users/alessiofanelli/.codex/skills/.system/skill-creator/scripts/init_skill.py visitt-visitor-management --path /Users/alessiofanelli/.codex/skills --interface display_name=\"Visitt Visitor Management\" --interface short_description=\"Invite office visitors from calendar or CSV\" --interface default_prompt=\"Use $visitt-visitor-management to add today's office visitors from my calendar or a CSV to Visitt.\""], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "curl -sS https://tcg-power-buyer.vercel.app/api/agent/query -H \"Authorization: Bearer $TCG_POWER_API_KEY\" -H \"Content-Type: application/json\" -d '{\"table\":\"products\",\"filters\":[{\"field\":\"id\",\"op\":\"in\",\"value\":[\"842664\",\"2253687\",\"762776\",\"889183\",\"842443\"]}],\"select\":[\"id\",\"productName\",\"setName\",\"consoleName\",\"prices.psa10\",\"url\",\"imageUrl\",\"data.url\",\"data.priceChartingUrl\",\"data.productUrl\",\"data.slug\",\"data.source\"],\"limit\":10,\"strictSelect\":false}' -o /private/tmp/tcg_top_product_records.json && node -e 'const j=JSON.parse(require(\"fs\").readFileSync(\"/private/tmp/tcg_top_product_records.json\",\"utf8\")); console.log(JSON.stringify({warnings:j.warnings,rows:j.rows},null,2));'"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "curl -sS https://tcg-power-buyer.vercel.app/api/import/psa-certs -H \"Authorization: Bearer $TCG_POWER_API_KEY\" -H \"Content-Type: application/json\" -d '{\"rows\":[{\"productId\":\"842664\",\"certNumber\":\"51178434\"}],\"psaMaxRetries\":5,\"psaRetryDelayMs\":3000,\"psaMaxRetryDelayMs\":20000}' -o /private/tmp/tcg_lugia_cert_import.json && node -e 'const fs=require(\"fs\"); const j=JSON.parse(fs.readFileSync(\"/private/tmp/tcg_lugia_cert_import.json\",\"utf8\")); const s=(j.snapshots||[])[0]||{}; console.log(JSON.stringify({attempted:j.attempted, imported:j.imported, skipped:j.skipped, failed:j.failed, snapshot:s&&{productId:s.productId,specId:s.specId,certNumber:s.certNumber,total:s.total,psa10:s.grades&&s.grades[\"10\"],source:s.source,capturedAt:s.capturedAt}},null,2));'"], decision="allow")
