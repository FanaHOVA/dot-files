{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "/Users/alessiofanelli/.git-ai/bin/git-ai checkpoint claude --hook-input stdin",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "/Users/alessiofanelli/.git-ai/bin/git-ai checkpoint claude --hook-input stdin",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "voiceEnabled": true
}
